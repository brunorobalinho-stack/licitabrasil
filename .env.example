# =============================================================================
# LicitaBrasil - environment template
# Copy this file to `.env` and fill in the REQUIRED values below.
# DO NOT commit your real .env file (it is in .gitignore).
# =============================================================================

# --- Database -----------------------------------------------------------------
POSTGRES_USER=licitabrasil
# REQUIRED. Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=
# DATABASE_URL: no fluxo Docker (`docker compose up`) o compose monta essa string
# a partir de POSTGRES_USER/POSTGRES_PASSWORD e ignora o valor abaixo -- nao
# precisa editar. Fora do Docker, troque o REPLACE_WITH... pela senha real.
# O app recusa o boot se o placeholder REPLACE_WITH continuar aqui.
DATABASE_URL="postgresql://licitabrasil:REPLACE_WITH_POSTGRES_PASSWORD@localhost:5432/licitabrasil"

# --- Redis --------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- JWT (REQUIRED in every environment, including dev) -----------------------
# Generate each one with: openssl rand -base64 48
# Must be at least 32 characters. The app refuses to start with any of the
# legacy default strings that used to live here.
# DO NOT reuse the same value across environments.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server -------------------------------------------------------------------
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# --- Scraping -----------------------------------------------------------------
PNCP_API_BASE="https://pncp.gov.br/api/consulta"
QUERIDO_DIARIO_API_BASE="https://queridodiario.ok.org.br/api"
SCRAPING_CONCURRENCY=3
SCRAPING_RATE_LIMIT_MS=1000

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
