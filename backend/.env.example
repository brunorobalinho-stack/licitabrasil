# =============================================================================
# Backend-only env template (use this when running `npm run dev` outside Docker)
# Copy to `backend/.env` and fill in the REQUIRED values below.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Troque REPLACE_WITH_DB_USER e REPLACE_WITH_DB_PASSWORD pelas credenciais reais.
# O app recusa o boot enquanto o placeholder REPLACE_WITH continuar aqui.
DATABASE_URL="postgresql://REPLACE_WITH_DB_USER:REPLACE_WITH_DB_PASSWORD@localhost:5432/licitabrasil"

# --- Redis --------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- JWT (REQUIRED) -----------------------------------------------------------
# Generate each one with: openssl rand -base64 48
# Must be at least 32 characters. The app refuses to start with any of the
# legacy default strings that used to live here.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server -------------------------------------------------------------------
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# --- Scraping -----------------------------------------------------------------
PNCP_API_BASE="https://pncp.gov.br/api/consulta"
QUERIDO_DIARIO_API_BASE="https://queridodiario.ok.org.br/api"
SCRAPING_CONCURRENCY=3
SCRAPING_RATE_LIMIT_MS=1000

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
